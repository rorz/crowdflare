{
  "mcpServers": {
    "discord-mcp": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "DISCORD_TOKEN",
        "-e",
        "DISCORD_GUILD_ID",
        "saseq/discord-mcp:latest"
      ],
      "env": {
        "DISCORD_TOKEN": "REPLACE_WITH_BOT_TOKEN",
        "DISCORD_GUILD_ID": "REPLACE_WITH_GUILD_ID"
      }
    }
  }
}
