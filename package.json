{
  "name": "crowdflare-crowdsource",
  "displayName": "Crowdflare Crowdsource",
  "description": "Crowdflare: VS Code/Cursor extension + crowd-driven agent rules (Discord MCP) for hackathon demos.",
  "version": "0.1.0",
  "publisher": "crowdflare",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "crowdflare.crowdsource",
        "title": "Crowdsource",
        "category": "Crowdflare",
        "icon": "$(broadcast)"
      }
    ],
    "keybindings": [
      {
        "command": "crowdflare.crowdsource",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "crowdflare.crowdsource",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Crowdflare",
      "properties": {
        "crowdflare.crowdsourcePrompt": {
          "type": "string",
          "default": "Crowdflare session: follow .cursor/rules/crowd-driven-agent.mdc for the full crowd loop. Admin brief for this run: build a small snake game in this repo.",
          "description": "Copied when running Crowdsource — paste into Agent Chat; edit the brief line per run."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
